# AI Engine API Keys (set at least one)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
PERPLEXITY_API_KEY=pplx-...
GOOGLE_API_KEY=AIza...

# Note: DeepEval uses OpenAI as its judge model by default.
# You need OPENAI_API_KEY set for evaluation to work,
# even if you're only querying other engines.

# Paths
LLM_DOCS_PATH=C:\GitRepos\llm-docs
